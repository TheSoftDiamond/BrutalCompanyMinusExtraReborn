<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFramework>netstandard2.1</TargetFramework>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
		<LangVersion>latest</LangVersion>
		<ProduceReferenceAssembly>False</ProduceReferenceAssembly>
		<Nullable>enable</Nullable>

		<Authors>SoftDiamond</Authors>
		<Product>BrutalCompanyMinusExtraReborn</Product>
		<ToolCommandName>BrutalCompanyMinusExtraReborn</ToolCommandName>

		<RootNamespace>BrutalCompanyMinus</RootNamespace>

		<RestoreAdditionalProjectSources>
			https://api.nuget.org/v3/index.json;
			https://nuget.bepinex.dev/v3/index.json;
			https://nuget.samboy.dev/v3/index.json;
		</RestoreAdditionalProjectSources>
	</PropertyGroup>

	<ItemGroup>
		<None Remove="Asset\asset" />
		<None Remove="Asset\bcm_assets" />
		<None Remove="Asset\bcm_customassets" />
		<None Remove="Asset\customassets" />
		<None Remove="Asset\customenemies" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.CSharp" Version="4.7.0" />
		<PackageReference Include="Newtonsoft.Json" Version="13.0.5-beta1" />
		<PackageReference Include="BepInEx.AssemblyPublicizer.MSBuild" Version="0.5.0-beta.2" PrivateAssets="all" />
		<PackageReference Include="BepInEx.Analyzers" Version="1.*" PrivateAssets="all" />
		<PackageReference Include="BepInEx.Core" Version="5.*" />
		<PackageReference Include="BepInEx.PluginInfoProps" Version="2.*" />
		<PackageReference Include="Rune580.Mods.LethalCompany.InputUtils" Version="0.7.12" /> 
		<!-- <PackageReference Include="UnityEngine.Modules" Version="2022.3.62" IncludeAssets="compile" PrivateAssets="all" /> -->
		<!-- <PackageReference Include="LethalCompany.GameLibs.Steam" Version="73.0.0-ngd.0" PrivateAssets="all" Publicize="true"/> -->
	</ItemGroup>

	<PropertyGroup>
		<!-- Steam library folder -->
		<SteamLibrary>D:\SteamLibrary\steamapps\common</SteamLibrary>

		<!-- Lethal Company plugins folder -->
		<PluginsFolder>$(SteamLibrary)\Lethal Company\BepInEx\plugins</PluginsFolder>

		<!-- Gale profile name -->
		<GaleProfile>BCDev80</GaleProfile>

		<!-- Gale plugins folder -->
		<GalePluginsFolder>$(AppData)\com.kesomannen.gale\lethal-company\profiles\$(GaleProfile)\BepInEx\plugins\SoftDiamond-BrutalCompanyMinusExtraReborn</GalePluginsFolder>

		<!-- Other settings -->
		<PlatformTarget>AnyCPU</PlatformTarget>
		<GenerateDocumentationFile>False</GenerateDocumentationFile>
		<UserSecretsId>3f41ed69-9911-4a88-a581-38559aa6aec1</UserSecretsId>
	</PropertyGroup>

